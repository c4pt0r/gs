# gs configuration file example
# Copy to gs.yaml, then: gs --config-file gs.yaml gmail tail
# (filters/output/monitoring below apply to `gs gmail tail`)

# Authentication settings
auth:
  # Path to OAuth2 credentials file downloaded from Google Cloud Console
  credentials_file: ~/.gs/credentials.json

  # Alternative: service account key file for server environments
  # auth_token: ~/.gs/service-account.json

  # Cached token location (created after `gs auth login`)
  cached_auth_token: ~/.gs/tokens

# Gmail filtering settings (used by `gs gmail tail`)
filters:
  # Gmail search query (uses Gmail search syntax)
  query: "label:important"

  # Alternative individual filters:
  # from: "noreply@github.com"
  # to: "me@example.com"
  # subject: "alert|error|warning"
  # labels: ["important", "inbox"]
  # has_attachment: true
  # unread_only: true
  # since: "2025-01-01T00:00:00Z"

# Output formatting (for `gs gmail tail`)
output:
  format: json-lines  # json, json-lines, compact
  include_body: true
  include_attachments: true
  max_body_length: 500
  pretty: false
  # fields: ["id", "subject", "from", "timestamp", "labels"]

# Monitoring behavior (for `gs gmail tail`)
monitoring:
  poll_interval: 60        # seconds between polls
  batch_size: 20           # messages per batch
  tail: true               # continuous monitoring
  # max_messages: 1000     # stop after processing this many messages

# Checkpoint settings
checkpoint:
  checkpoint_file: ~/.gs/checkpoint
  checkpoint_interval: 120  # save checkpoint every 2 minutes
  resume: true              # resume from last checkpoint on startup

# Logging
verbose: false
quiet: false
# log_file: ~/.gs/gs.log
